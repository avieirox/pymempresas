<div id="cookie-overlay" class="cookie-overlay hidden">
  <div class="cookie-modal">
    <div class="cookie-head">
      <div class="cookie-head-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
          <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/>
          <path d="M8.5 8.5v.01"/>
          <path d="M16 15.5v.01"/>
          <path d="M12 12v.01"/>
          <path d="M11 17v.01"/>
          <path d="M7 14v.01"/>
        </svg>
      </div>
      <div>
        <h2 class="cookie-head-title">Configuración de cookies</h2>
        <p class="cookie-head-subtitle">Personaliza tus preferencias de privacidad</p>
      </div>
    </div>

    <p class="cookie-desc">
      Utilizamos cookies para mejorar tu experiencia, analizar el tráfico y mostrar contenido relevante. Puedes elegir qué categorías aceptar.
    </p>

    <div class="cookie-categories">
      <label class="cookie-category">
        <div class="cookie-cat-info">
          <span class="cookie-cat-name">Cookies necesarias</span>
          <span class="cookie-cat-desc">Requeridas para el funcionamiento básico del sitio. No se pueden desactivar.</span>
        </div>
        <input type="checkbox" checked disabled class="cookie-toggle">
        <span class="cookie-switch cookie-switch-disabled"></span>
      </label>

      <label class="cookie-category">
        <div class="cookie-cat-info">
          <span class="cookie-cat-name">Cookies analíticas</span>
          <span class="cookie-cat-desc">Nos ayudan a entender cómo usas el sitio para mejorarlo.</span>
        </div>
        <input type="checkbox" id="cookie-analytics" checked class="cookie-toggle">
        <span class="cookie-switch"></span>
      </label>

      <label class="cookie-category">
        <div class="cookie-cat-info">
          <span class="cookie-cat-name">Cookies de marketing</span>
          <span class="cookie-cat-desc">Permiten mostrar anuncios relevantes para ti.</span>
        </div>
        <input type="checkbox" id="cookie-marketing" checked class="cookie-toggle">
        <span class="cookie-switch"></span>
      </label>
    </div>

    <div class="cookie-actions">
      <button id="cookie-accept-all" class="cookie-btn cookie-btn-primary">Aceptar todas</button>
      <button id="cookie-save" class="cookie-btn cookie-btn-outline">Guardar preferencias</button>
      <button id="cookie-reject-all" class="cookie-btn cookie-btn-ghost">Rechazar todas</button>
    </div>

    <div class="cookie-footer">
      <a href="/politica-privacidad/">Política de privacidad</a>
      <span>·</span>
      <a href="/aviso-legal/">Aviso legal</a>
    </div>
  </div>
</div>

<script>
  const COOKIE_KEY = 'pymempresas-cookie-consent';
  const overlay = document.getElementById('cookie-overlay')!;
  const analyticsCheck = document.getElementById('cookie-analytics') as HTMLInputElement;
  const marketingCheck = document.getElementById('cookie-marketing') as HTMLInputElement;

  if (!localStorage.getItem(COOKIE_KEY)) {
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeCookies() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function savePreferences(prefs: Record<string, boolean>) {
    localStorage.setItem(COOKIE_KEY, JSON.stringify(prefs));
    closeCookies();
  }

  document.getElementById('cookie-accept-all')?.addEventListener('click', () => {
    savePreferences({ necessary: true, analytics: true, marketing: true });
  });

  document.getElementById('cookie-reject-all')?.addEventListener('click', () => {
    savePreferences({ necessary: true, analytics: false, marketing: false });
  });

  document.getElementById('cookie-save')?.addEventListener('click', () => {
    savePreferences({
      necessary: true,
      analytics: analyticsCheck.checked,
      marketing: marketingCheck.checked,
    });
  });
</script>

