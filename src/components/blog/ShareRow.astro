---
interface Props {
  url: string;
  title: string;
  author?: string;
  authorBio?: string;
  authorLinkedin?: string;
  authorTwitter?: string;
  authorImage?: string;
}

const {
  url, title: articleTitle,
  author, authorBio, authorLinkedin, authorTwitter, authorImage,
} = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(articleTitle);
---

<div class="share-section">
  {author && (
    <div class="author-card">
      {authorImage && <img src={authorImage} alt={author} class="author-card-avatar" />}
      <div class="author-card-body">
        <span class="author-card-label">Escrito por</span>
        <span class="author-card-name">{author}</span>
        {authorBio && <p class="author-card-bio">{authorBio}</p>}
        {(authorLinkedin || authorTwitter) && (
          <div class="author-card-socials">
            {authorLinkedin && (
              <a href={authorLinkedin} target="_blank" rel="noopener noreferrer" class="author-social-link" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
            {authorTwitter && (
              <a href={authorTwitter} target="_blank" rel="noopener noreferrer" class="author-social-link" aria-label="Twitter">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  )}

  <div class="share-row">
    <span class="share-label">Compartir artículo</span>
    <div class="share-btns">
      <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Twitter">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <button class="share-btn share-btn-copy" aria-label="Copiar enlace" data-url={url}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        <span class="share-copy-toast" aria-live="polite"></span>
      </button>
      <a href={`mailto:?subject=${encodedTitle}&body=${encodedUrl}`} class="share-btn" aria-label="Email">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.share-btn-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLElement).dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const toast = btn.querySelector('.share-copy-toast') as HTMLElement;
        if (toast) { toast.textContent = 'Copiado'; toast.classList.add('show'); setTimeout(() => toast.classList.remove('show'), 1800); }
      } catch {}
    });
  });
</script>

<style>
  .share-section {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  .author-card {
    background: #F8F9FA;
    border: 1px solid #EAECEF;
    border-radius: 12px;
    padding: 28px 32px;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .author-card-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .author-card-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #AAA;
    margin-bottom: 4px;
  }
  .author-card-name {
    display: block;
    font-size: 18px;
    font-weight: 700;
    color: #0A0A0A;
    margin-bottom: 6px;
  }
  .author-card-bio {
    color: #666;
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .author-card-socials {
    display: flex;
    gap: 8px;
  }
  .author-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: #fff;
    border: 1px solid #EAECEF;
    color: #888;
    transition: all 0.15s;
  }
  .author-social-link:hover {
    border-color: #F5A623;
    color: #F5A623;
    background: #FFF8E8;
  }

  .share-row {
    border-top: 1px solid #EAECEF;
    padding-top: 28px;
    text-align: center;
  }
  .share-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #AAA;
    margin-bottom: 14px;
    display: block;
  }
  .share-btns {
    display: flex;
    justify-content: center;
    gap: 8px;
  }
  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    border: 1px solid #EAECEF;
    background: #fff;
    color: #888;
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
    text-decoration: none;
  }
  .share-btn:hover {
    background: #F8F9FA;
    border-color: #CDD1D9;
    color: #0A0A0A;
  }
  .share-copy-toast {
    position: absolute;
    top: -34px;
    left: 50%;
    transform: translateX(-50%);
    background: #0A0A0A;
    color: #fff;
    font-size: 11px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    font-family: system-ui, sans-serif;
  }
  .share-copy-toast.show { opacity: 1; }

  @media (max-width: 768px) {
    .author-card { padding: 20px; }
  }
</style>
