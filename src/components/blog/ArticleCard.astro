---
export interface Props {
  slug: string;
  title: string;
  description: string;
  image?: string;
  tags?: string[];
  date: Date;
  author: string;
  index?: number;
}

const {
  slug,
  title,
  description,
  image,
  tags = [],
  date,
  author,
  index = 0,
} = Astro.props;

const dateStr = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="card" style={`--i: ${index}`}>
  {image ? (
    <a href={`/${slug}/`} class="card-media">
      <img src={image} alt={title} loading="lazy" decoding="async" class="card-img" />
    </a>
  ) : (
    <a href={`/${slug}/`} class="card-media card-media-empty">
      <span class="card-media-letter">{title.charAt(0)}</span>
    </a>
  )}
  <div class="card-body">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 2).map((tag) => <span class="card-tag">{tag}</span>)}
      </div>
    )}
    <h2 class="card-title"><a href={`/${slug}/`}>{title}</a></h2>
    <p class="card-desc">{description}</p>
    <div class="card-meta">
      <time datetime={date.toISOString()}>{dateStr}</time>
      <span aria-hidden="true">·</span>
      <span>{author}</span>
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #EAECEF;
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    transform: translateY(-2px);
  }

  .card-media {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #F0F1F3;
  }
  .card-media-empty {
    background: linear-gradient(135deg, #F8F9FA 0%, #EAECEF 100%);
  }
  .card-media-letter {
    font-size: 48px;
    font-weight: 800;
    color: #CDD1D9;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .card:hover .card-img {
    transform: scale(1.04);
  }

  .card-body {
    padding: 22px 24px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-tags {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
  }
  .card-tag {
    font-size: 11px;
    font-weight: 600;
    color: #E8960F;
    background: #FFF8E8;
    padding: 3px 10px;
    border-radius: 100px;
    letter-spacing: 0.01em;
  }

  .card-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  .card-title a {
    color: #0A0A0A;
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-title a:hover {
    color: #F5A623;
  }

  .card-desc {
    color: #777;
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 14px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    color: #AAA;
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
  }
</style>
