---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/constants';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${SITE.url}/automatizaciones-con-ia/#service`,
      name: 'Automatizaciones con Inteligencia Artificial para Empresas',
      description: 'Transforma tu negocio con automatizaciones inteligentes. Ahorra tiempo, reduce errores y aumenta la productividad con soluciones de IA diseñadas para empresas de Gijón y Asturias.',
      url: `${SITE.url}/automatizaciones-con-ia/`,
      provider: { '@id': `${SITE.url}/#business` },
      areaServed: [
        { '@type': 'City', name: 'Gijón' },
        { '@type': 'State', name: 'Asturias' },
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Soluciones de Automatización',
        itemListElement: [{
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Automatización con IA',
          },
          price: '995',
          priceCurrency: 'EUR',
        }],
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Automatizaciones con IA' },
      ],
    },
  ],
};
---

<BaseLayout
  metaTitle="Automatizaciones con IA para Empresas en Gijón | PYMEMPRESAS"
  metaDescription="Automatiza tu negocio con IA en Gijón y Asturias. Ahorra tiempo, reduce errores y aumenta la productividad. Soluciones personalizadas para empresas."
  canonicalURL="https://pymempresas.com/automatizaciones-con-ia/"
  schema={schema}
>
  <!-- HERO AUTOMATIZACIONES IA -->
  <section class="ia-hero-section" style="background: linear-gradient(135deg, rgba(40, 40, 40, 0.95), rgba(80, 60, 40, 0.85));">
    <div class="ia-hero-container">
      <div class="ia-badge" style="background: rgba(255, 255, 255, 0.15); border-color: rgba(255, 255, 255, 0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
        </svg>
        <span style="color: #ffffff;">Automatización Inteligente en Gijón</span>
      </div>
      <h1 class="ia-hero-title" style="color: #ffffff;">
        Automatizaciones con<br>Inteligencia Artificial para<br>Empresas en Gijón
      </h1>
      <p class="ia-hero-description" style="color: rgba(255, 255, 255, 0.9);">
        Transforma tu negocio con automatizaciones inteligentes. Ahorra tiempo, reduce errores y aumenta la productividad con soluciones de IA diseñadas para empresas de Gijón y Asturias.
      </p>
      <div class="ia-hero-buttons">
        <a href="#contacto" class="ia-btn-primary" style="background: #ffffff; color: #1a1a1a; box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
            <path d="M9 11l3 3L22 4"></path>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
          </svg>
          Solicitar Diagnóstico Gratis
        </a>
        <a href="#ejemplos" class="ia-btn-secondary" style="color: #ffffff; border-color: rgba(255, 255, 255, 0.5); background: rgba(255, 255, 255, 0.1);">
          Ver Ejemplos
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 8px;">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SECCIÓN QUÉ ES LA AUTOMATIZACIÓN CON IA -->
  <section class="ia-benefits-section">
    <div class="ia-benefits-container">
      <div style="max-width: 1000px; margin: 0 auto 50px;">
        <h2 class="ia-benefits-title" style="text-align: left; margin-bottom: 20px;">
          ¿Qué es la automatización con IA y cómo funciona?
        </h2>
        <p style="font-size: 16px; line-height: 1.7; color: #666; margin: 0;">
          La <strong style="color: #1a1a1a;">automatización con Inteligencia Artificial</strong> combina la ejecución automática de tareas con la capacidad de aprendizaje y adaptación de la IA. A diferencia de la automatización tradicional (que sigue reglas fijas), la automatización con IA puede:
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; margin-bottom: 50px;">
        <div style="background: #FFFBF5; border: 1px solid #F5E5C0; border-radius: 16px; padding: 40px 30px; text-align: center; transition: all 0.3s ease;">
          <div style="width: 70px; height: 70px; margin: 0 auto 25px; background: #FFF8E8; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"></path>
              <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"></path>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0 0 15px; line-height: 1.3;">Aprender</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Mejora con cada interacción y se adapta a nuevos patrones</p>
        </div>
        <div style="background: #FFFBF5; border: 1px solid #F5E5C0; border-radius: 16px; padding: 40px 30px; text-align: center; transition: all 0.3s ease;">
          <div style="width: 70px; height: 70px; margin: 0 auto 25px; background: #FFF8E8; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0 0 15px; line-height: 1.3;">Entender</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Procesa lenguaje natural y comprende el contexto</p>
        </div>
        <div style="background: #FFFBF5; border: 1px solid #F5E5C0; border-radius: 16px; padding: 40px 30px; text-align: center; transition: all 0.3s ease;">
          <div style="width: 70px; height: 70px; margin: 0 auto 25px; background: #FFF8E8; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0 0 15px; line-height: 1.3;">Decidir</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Toma decisiones basadas en datos y probabilidades</p>
        </div>
      </div>
      <div style="max-width: 1000px; margin: 0 auto;">
        <p style="font-size: 16px; line-height: 1.7; color: #666; margin: 0;">
          Para las <strong style="color: #1a1a1a;">empresas de Gijón</strong>, esto significa poder automatizar tareas que antes requerían intervención humana constante: responder emails, clasificar documentos, atender clientes, analizar datos y mucho más.
        </p>
      </div>
    </div>
  </section>

  <!-- SECCIÓN QUÉ SE PUEDE AUTOMATIZAR CON IA -->
  <section class="ia-services-section">
    <div class="ia-services-container">
      <div class="ia-services-header">
        <h2 class="ia-services-title">¿Qué se puede automatizar con IA en las empresas?</h2>
        <p class="ia-services-subtitle">Ejemplos prácticos de automatización para negocios en Gijón</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px;">
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8B7355, #6B5744); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Atención al Cliente</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Chatbots inteligentes que responden 24/7, resuelven dudas frecuentes y escalan casos complejos automáticamente.</p>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8B7355, #6B5744); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Gestión Documental</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Extracción automática de datos de facturas, contratos y documentos. Clasificación y archivo inteligente.</p>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8B7355, #6B5744); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Marketing y Ventas</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Segmentación de clientes, emails personalizados, análisis de leads y predicción de comportamiento de compra.</p>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8B7355, #6B5744); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Contabilidad y Finanzas</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Conciliación bancaria automática, detección de anomalías, generación de informes y previsiones financieras.</p>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8B7355, #6B5744); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Recursos Humanos</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Cribado de CVs, programación de entrevistas, onboarding automatizado y análisis de clima laboral.</p>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #8B7355, #6B5744); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ffffff;">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 1v6m0 6v6"></path>
              <path d="m4.93 4.93 4.24 4.24m5.66 5.66 4.24 4.24"></path>
              <path d="M1 12h6m6 0h6"></path>
              <path d="m4.93 19.07 4.24-4.24m5.66-5.66 4.24-4.24"></path>
            </svg>
          </div>
          <h3 style="font-size: 20px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Operaciones y Logística</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Gestión de inventario predictiva, optimización de rutas, control de calidad y mantenimiento preventivo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN TIPOS DE AUTOMATIZACIÓN Y SISTEMAS DE IA -->
  <section class="ia-comparison-section">
    <div class="ia-comparison-container">
      <div class="ia-comparison-header">
        <h2 class="ia-comparison-title">Tipos de automatización y sistemas de IA</h2>
        <p class="ia-comparison-subtitle">Los 3 tipos principales de automatización y los 4 sistemas de IA</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; margin-top: 50px;">
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; position: relative; overflow: hidden; transition: all 0.3s ease;">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #3B82F6, #06B6D4);"></div>
          <h3 style="font-size: 22px; font-weight: 700; color: #1a1a1a; margin: 15px 0 0; line-height: 1.3;">Automatización Robótica (RPA)</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Robots software que imitan acciones humanas repetitivas: copiar datos, rellenar formularios, enviar emails.</p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Introducir datos en sistemas</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Generar informes periódicos</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Sincronizar bases de datos</span>
            </li>
          </ul>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; position: relative; overflow: hidden; transition: all 0.3s ease;">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #8B5CF6, #EC4899);"></div>
          <h3 style="font-size: 22px; font-weight: 700; color: #1a1a1a; margin: 15px 0 0; line-height: 1.3;">Automatización de Procesos</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Flujos de trabajo automáticos que conectan aplicaciones y ejecutan tareas según reglas predefinidas.</p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Workflows de aprobación</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Integraciones entre apps</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Alertas automáticas</span>
            </li>
          </ul>
        </div>
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; position: relative; overflow: hidden; transition: all 0.3s ease;">
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #F97316, #EF4444);"></div>
          <h3 style="font-size: 22px; font-weight: 700; color: #1a1a1a; margin: 15px 0 0; line-height: 1.3;">Automatización Cognitiva (IA)</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Sistemas que aprenden, comprenden lenguaje natural y toman decisiones basadas en datos.</p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Análisis de sentimiento</span>
