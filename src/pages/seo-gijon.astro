---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://pymempresas.com/#localbusiness",
      "name": "PYMEMPRESAS",
      "url": "https://pymempresas.com",
      "telephone": "+34 697 71 13 44",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "C. Rodríguez San Pedro, 1, Centro",
        "addressLocality": "Gijón",
        "addressRegion": "Asturias",
        "postalCode": "33206",
        "addressCountry": "ES"
      },
      "areaServed": ["Gijón", "Oviedo", "Avilés", "Asturias"],
      "priceRange": "€€"
    },
    {
      "@type": "Service",
      "@id": "https://pymempresas.com/seo-gijon/#service",
      "serviceType": "Consultoría SEO",
      "name": "Consultoría SEO en Gijón",
      "description": "Servicio de consultoría y posicionamiento SEO en Gijón para negocios locales. Auditoría gratuita, estrategia personalizada y resultados medibles. Más de 10 años de experiencia.",
      "url": "https://pymempresas.com/seo-gijon/",
      "provider": {
        "@id": "https://pymempresas.com/#business"
      },
      "areaServed": [
        { "@type": "City", "name": "Gijón" },
        { "@type": "AdministrativeArea", "name": "Asturias" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Consultoría SEO",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Auditoría SEO" },
            "price": "0",
            "priceCurrency": "EUR",
            "description": "Auditoría SEO inicial gratuita para evaluar el estado de tu web."
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Consultoría SEO Mensual" },
            "price": "397",
            "priceCurrency": "EUR",
            "description": "Consultoría SEO continuada con optimización mensual y reportes de resultados."
          }
        ]
      }
    },
    {
      "@type": "WebPage",
      "@id": "https://pymempresas.com/seo-gijon/#webpage",
      "url": "https://pymempresas.com/seo-gijon/",
      "name": "SEO en Gijón — Consultoría y Posicionamiento Web | PYMEMPRESAS",
      "description": "Consultor SEO en Gijón especializado en negocios locales. Auditoría gratuita, estrategia personalizada y resultados medibles. Más de 10 años de experiencia.",
      "inLanguage": "es-ES",
      "isPartOf": { "@id": "https://pymempresas.com/#website" },
      "about": { "@id": "https://pymempresas.com/seo-gijon/#service" },
      "breadcrumb": { "@id": "https://pymempresas.com/seo-gijon/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://pymempresas.com/seo-gijon/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://pymempresas.com/" },
        { "@type": "ListItem", "position": 2, "name": "SEO en Gijón", "item": "https://pymempresas.com/seo-gijon/" }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://pymempresas.com/seo-gijon/#faqpage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué hace un consultor SEO en Gijón?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un consultor SEO analiza tu web, detecta problemas que impiden que Google te posicione bien y ejecuta mejoras técnicas, de contenido y de autoridad para que tu negocio aparezca en los primeros resultados cuando tus clientes te buscan en Gijón y Asturias."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta contratar un consultor SEO en Gijón?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La consultoría SEO en Gijón parte desde 397€/mes para un servicio continuado. También ofrecemos auditorías puntuales desde 250€. El precio varía según la complejidad del proyecto y el nivel de competencia de tu sector. Solicitando una auditoría gratuita podemos darte un presupuesto ajustado."
          }
        },
        {
          "@type": "Question",
          "name": "¿En cuánto tiempo se ven resultados del SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los primeros resultados suelen notarse entre el mes 3 y 6. Depende de factores como la competencia en tu sector, la antigüedad de tu dominio y el estado actual de tu web. En sectores locales de Gijón con competencia moderada, es habitual ver mejoras significativas a partir del cuarto mes."
          }
        },
        {
          "@type": "Question",
          "name": "¿Necesito cambiar mi web actual para hacer SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No siempre. Si tu web tiene buena base técnica (carga rápida, diseño responsive, URLs limpias), podemos trabajar sobre ella. Si es antigua o no está optimizada para móviles, una renovación acelerará los resultados. En la auditoría inicial evaluamos tu caso y te damos una recomendación clara."
          }
        },
        {
          "@type": "Question",
          "name": "¿Trabajáis con negocios de cualquier sector en Gijón?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Trabajamos con clínicas, despachos profesionales, comercios, hostelería, empresas industriales y de servicios. Cada sector tiene sus particularidades, pero la metodología de análisis, optimización y medición de resultados se adapta a cualquier tipo de negocio local."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué diferencia hay entre SEO local y SEO general?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El SEO general busca posicionar a nivel nacional o internacional. El SEO local se centra en que te encuentren clientes de Gijón y Asturias, incluyendo optimización de Google Business Profile, reseñas y directorios locales. Para un negocio que vive de clientes de su zona, el SEO local es mucho más rentable."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  metaTitle="Consultor SEO en GIJON | Auditoria WEB | PYMEMPRESAS"
  metaDescription="Consultor SEO en Gijón especializado en negocios locales. Auditoría gratuita, estrategia personalizada y resultados medibles. Más de 10 años de experiencia."
  canonicalURL="https://pymempresas.com/seo-gijon/"
  schema={schema}
>

  <!-- HERO -->
  <div class="hero-pymempresas-wrapper">
    <div class="hero-pymempresas seo-hero-light">
      <div class="hero-content hero-content-center">
        <div class="hero-badge seo-badge">
          <svg class="hero-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span>Especialistas en Gijón, Asturias</span>
        </div>

        <h1 class="hero-title seo-title">Consultor <span class="text-highlight">SEO en Gijón</span></h1>

        <p class="hero-subtitle seo-subtitle">Cuando alguien busca tu servicio en Google, tu negocio debería aparecer el primero. No el segundo, no en la página dos. El primero. Como <strong>consultor SEO en Gijón</strong>, mi trabajo es que tu web deje de ser invisible y empiece a traerte clientes cada día. Sin trucos, sin magia: con estrategia, datos y trabajo constante.</p>

        <div class="hero-buttons">
          <a href="/consultoria/" class="hero-btn-primary seo-btn-primary">Auditoría SEO Gratuita</a>
          <a href="#proceso" class="hero-btn-secondary seo-btn-secondary">Cómo Trabajamos</a>
        </div>
      </div>
    </div>
  </div>

  <!-- QUÉ HACE UN CONSULTOR SEO -->
  <section class="about-pymempresas seo-what-is">
    <div class="advantages-container">
      <div class="seo-intro-header">
        <h2 class="advantages-title">¿Qué hace un <span class="text-highlight">consultor SEO</span> en Gijón?</h2>
        <p class="advantages-subtitle">Un consultor SEO es el profesional que diagnostica por qué tu web no aparece en Google y ejecuta las mejoras necesarias para que pase de invisible a primera página.</p>
      </div>

      <div class="seo-content-grid-new">
        <div class="seo-text-content">
          <p>El trabajo de un <strong>consultor SEO en Gijón</strong> va mucho más allá de instalar un plugin y esperar. Consiste en analizar a fondo tu negocio, tu competencia local y las palabras clave que usan tus clientes para buscar tus servicios.</p>

          <p>A partir de ese análisis, se diseña una estrategia que abarca tres frentes: la <strong>parte técnica</strong> de tu web (velocidad, indexación, estructura), el <strong>contenido</strong> (textos optimizados para lo que busca tu cliente) y la <strong>autoridad</strong> (conseguir que otros sitios relevantes enlacen al tuyo).</p>

          <p>En Gijón, la competencia digital crece cada año. Negocios que ignoran el SEO pierden clientes frente a competidores que sí invierten en ser visibles. Un consultor SEO te da la ventaja de aparecer cuando el cliente ya ha decidido comprar y solo busca <em>a quién</em>.</p>
        </div>

        <div class="seo-example-card">
          <div class="seo-example-header">
            <svg class="seo-example-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            <h3>Tareas del consultor SEO</h3>
          </div>

          <div class="seo-example-content">
            <div class="seo-example-steps">
              <div class="seo-step">
                <svg class="check-icon check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>Auditoría técnica de tu sitio web</span>
              </div>
              <div class="seo-step">
                <svg class="check-icon check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>Investigación de palabras clave locales</span>
              </div>
              <div class="seo-step">
                <svg class="check-icon check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>Optimización de contenido y metadatos</span>
              </div>
              <div class="seo-step">
                <svg class="check-icon check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>Estrategia de link building local</span>
              </div>
              <div class="seo-step">
                <svg class="check-icon check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>Gestión de Google Business Profile</span>
              </div>
              <div class="seo-step">
                <svg class="check-icon check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>Informes mensuales de resultados</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS SEO -->
  <section class="advantages-pymempresas">
    <div class="advantages-container">
      <div class="advantages-header">
        <h2 class="advantages-title">Servicios <span class="text-highlight">SEO</span> para negocios en Gijón</h2>
        <p class="advantages-subtitle">Soluciones adaptadas al tamaño de tu negocio, sector y nivel de competencia en el área de Gijón</p>
      </div>

      <div class="seo-types-grid">
        <div class="seo-type-card">
          <div class="seo-type-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </div>
          <h3 class="seo-type-title">Auditoría SEO</h3>
          <p class="seo-type-description">Análisis completo de tu web: velocidad, indexación, contenido, backlinks y posicionamiento actual respecto a tu competencia en Gijón.</p>
          <ul class="seo-type-features">
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Análisis técnico de indexación</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Investigación de palabras clave</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Análisis de competidores locales</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Informe con recomendaciones</span></li>
          </ul>
        </div>

        <div class="seo-type-card">
          <div class="seo-type-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <h3 class="seo-type-title">SEO On-Page</h3>
          <p class="seo-type-description">Optimización de todo el contenido y estructura de tu web para que Google entienda exactamente de qué va tu negocio.</p>
          <ul class="seo-type-features">
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Títulos y meta descripciones</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Estructura de encabezados</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Contenido optimizado</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Velocidad de carga</span></li>
          </ul>
        </div>

        <div class="seo-type-card">
          <div class="seo-type-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
          </div>
          <h3 class="seo-type-title">Link Building</h3>
          <p class="seo-type-description">Construcción de enlaces desde sitios de calidad que aumentan la autoridad de tu dominio ante Google.</p>
          <ul class="seo-type-features">
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Guest posting en medios</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Directorios de calidad</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Colaboraciones locales</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Menciones sin enlace</span></li>
          </ul>
        </div>

        <div class="seo-type-card seo-local-featured">
          <div class="seo-type-icon seo-local-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="seo-type-header">
            <h3 class="seo-type-title">SEO Local Gijón</h3>
            <span class="recommended-badge">Más demandado</span>
          </div>
          <p class="seo-type-description">Estrategia integral para que tu negocio domine las búsquedas locales: Google Maps, Google Business Profile y directorios de Asturias.</p>
          <ul class="seo-type-features">
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Google Business Profile</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Google Maps y Local Pack</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Reseñas y reputación</span></li>
            <li><svg class="feature-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Directorios asturianos</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- POR QUÉ PYMEMPRESAS -->
  <section class="about-pymempresas seo-what-is">
    <div class="advantages-container">
      <div class="seo-intro-header">
        <h2 class="advantages-title">¿Por qué elegir <span class="text-highlight">PYMEMPRESAS</span> como tu agencia SEO en Gijón?</h2>
        <p class="advantages-subtitle">Más de 10 años ayudando a negocios de Asturias a crecer con estrategias de posicionamiento web</p>
      </div>

      <div class="seo-content-grid-new">
