      </div>
    </div>
  </section>

  <!-- PROCESO DE TRABAJO -->
  <section class="advantages-pymempresas" id="proceso">
    <div class="advantages-container">
      <div class="advantages-header">
        <h2 class="advantages-title">Proceso de <span class="text-highlight">trabajo</span></h2>
        <p class="advantages-subtitle">Cómo convertimos tu web invisible en una máquina de captar clientes en Gijón</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 50px;">
        <div style="background: #fff; border: 1px solid #e8e6e1; border-radius: 16px; padding: 30px 24px; text-align: center;">
          <div style="width: 56px; height: 56px; background: #FFF8E8; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
