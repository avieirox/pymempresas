              </svg>
              <span>Investigación de usuarios</span>
            </li>
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Wireframes y prototipos</span>
            </li>
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Tests de usabilidad</span>
            </li>
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Diseño centrado en conversión</span>
            </li>
          </ul>
        </div>

        <!-- Tarjeta 3: Diseno Adaptativo -->
        <div class="web-type-card">
          <div class="web-type-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>

          <h3 class="web-type-name">Diseño Adaptativo</h3>

          <p class="web-type-description">Layouts específicos para cada tamaño de pantalla, maximizando la experiencia.</p>

          <ul class="web-type-features">
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Breakpoints personalizados</span>
            </li>
            <li>
