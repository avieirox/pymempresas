  <!-- DEVELOPMENT PHASES -->
  <section class="web-phases-section">
    <div class="advantages-container">
      <div class="web-phases-header">
        <h2 class="web-phases-title">Fases del <span class="text-highlight">Diseño Web</span></h2>
