      </div>

      <div class="web-phases-grid">
        <!-- Fase 1: Planificacion -->
        <div class="phase-card">
          <div class="phase-number">01</div>
          <div class="phase-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <h3 class="phase-name">Planificación</h3>
          <p class="phase-description">Analizamos tu negocio, competencia y objetivos. Definimos la estructura, funcionalidades y estrategia de contenido.</p>
          <span class="phase-duration">1-2 semanas</span>
        </div>

        <!-- Fase 2: Diseno -->
        <div class="phase-card">
          <div class="phase-number">02</div>
          <div class="phase-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
              <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
              <path d="M2 2l7.586 7.586"></path>
              <circle cx="11" cy="11" r="2"></circle>
            </svg>
          </div>
          <h3 class="phase-name">Diseño</h3>
          <p class="phase-description">Creamos wireframes y mockups. Diseñamos la identidad visual, paleta de colores y tipografías alineadas con tu marca.</p>
          <span class="phase-duration">1-2 semanas</span>
        </div>

        <!-- Fase 3: Desarrollo -->
        <div class="phase-card">
          <div class="phase-number">03</div>
          <div class="phase-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <h3 class="phase-name">Desarrollo</h3>
          <p class="phase-description">Programamos tu web con código limpio y optimizado. Integramos CMS, formularios y funcionalidades específicas.</p>
          <span class="phase-duration">2-4 semanas</span>
        </div>

        <!-- Fase 4: Pruebas -->
        <div class="phase-card">
          <div class="phase-number">04</div>
          <div class="phase-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <h3 class="phase-name">Pruebas</h3>
          <p class="phase-description">Testing exhaustivo en múltiples dispositivos y navegadores. Verificamos rendimiento, seguridad y usabilidad.</p>
          <span class="phase-duration">1 semana</span>
        </div>

        <!-- Fase 5: Lanzamiento -->
        <div class="phase-card">
          <div class="phase-number">05</div>
          <div class="phase-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M2 12h20"></path>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          <h3 class="phase-name">Lanzamiento</h3>
          <p class="phase-description">Desplegamos tu web en producción. Configuramos dominio, SSL, analytics y optimización SEO inicial.</p>
          <span class="phase-duration">2-3 días</span>
        </div>

        <!-- Fase 6: Mantenimiento -->
        <div class="phase-card">
          <div class="phase-number">06</div>
          <div class="phase-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 1v6m0 6v6M5.64 5.64l4.24 4.24m4.24 4.24l4.24 4.24M1 12h6m6 0h6M5.64 18.36l4.24-4.24m4.24-4.24l4.24-4.24"></path>
            </svg>
          </div>
          <h3 class="phase-name">Mantenimiento</h3>
          <p class="phase-description">Actualizaciones de seguridad, backups, monitorización del rendimiento y soporte técnico continuo.</p>
          <span class="phase-duration">Continuo</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING SECTION -->
  <section class="web-pricing-section">
    <div class="advantages-container">
      <div class="web-pricing-header">
        <h2 class="web-pricing-title">Precios de <span class="text-highlight">Diseño Web</span> en Gijón</h2>
        <p class="web-pricing-subtitle">Soluciones adaptadas a cada presupuesto. Precios transparentes sin sorpresas.</p>
      </div>

      <div class="web-pricing-grid">
        <!-- Plan 1: Web Basica -->
        <div class="web-pricing-card">
          <h3 class="web-plan-name">Web Básica</h3>

          <div class="web-plan-price">
            <span class="web-price-currency">€</span>
            <span class="web-price-amount">997</span>
          </div>

          <p class="web-plan-payment">pago único</p>

          <p class="web-plan-description">Perfecta para autónomos y pequeños negocios</p>

          <ul class="web-plan-features">
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Hasta 5 páginas</span>
            </li>
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Diseño responsivo</span>
