              </svg>
              <span>Contenido optimizado por pantalla</span>
            </li>
            <li>
              <svg class="feature-check-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
