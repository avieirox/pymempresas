---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://pymempresas.com/#organization",
      "name": "PYMEMPRESAS",
      "url": "https://pymempresas.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://pymempresas.com/images/logo-header.webp",
        "width": 801,
        "height": 247
      },
      "description": "Impulsa tu negocio local con estrategias de SEO, desarrollo web, inteligencia artificial y automatizaciones en Gijón y Asturias.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "C. Rodríguez San Pedro, 1, Centro",
        "addressLocality": "Gijón",
        "addressRegion": "Asturias",
        "postalCode": "33206",
        "addressCountry": "ES"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@pymempresas.com",
        "contactType": "customer service",
        "areaServed": "ES",
        "availableLanguage": "Spanish"
      },
      "sameAs": [
        "https://pymempresas.com"
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://pymempresas.com/formacion-ia-empresas/#webpage",
      "url": "https://pymempresas.com/formacion-ia-empresas/",
      "name": "Formación en Inteligencia Artificial para Empresas en Gijón",
      "description": "Capacita a tu equipo con cursos prácticos de IA en Gijón y Asturias. Aumenta la productividad hasta un 40% con formación especializada en inteligencia artificial.",
      "isPartOf": {
        "@id": "https://pymempresas.com/#website"
      },
      "about": {
        "@id": "https://pymempresas.com/#organization"
      },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "https://pymempresas.com/images/logo-header.webp"
      },
      "datePublished": "2026-01-01T00:00:00+00:00",
      "dateModified": "2026-01-12T00:00:00+00:00"
    },
    {
      "@type": "Service",
      "@id": "https://pymempresas.com/formacion-ia-empresas/#service",
      "serviceType": "Formación en Inteligencia Artificial",
      "name": "Formación en Inteligencia Artificial para Empresas",
      "description": "Cursos prácticos de IA para empresas en Gijón y Asturias. Capacita a tu equipo en ChatGPT, automatización, machine learning y más.",
      "provider": {
        "@id": "https://pymempresas.com/#organization"
      },
      "areaServed": {
        "@type": "City",
        "name": "Gijón",
        "containedIn": {
          "@type": "AdministrativeArea",
          "name": "Asturias"
        }
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Cursos de Inteligencia Artificial",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Course",
              "name": "Curso de IA para Principiantes",
              "description": "Formación introductoria ideal para empleados sin experiencia técnica. 16 horas en formato presencial u online.",
              "provider": {
                "@id": "https://pymempresas.com/#organization"
              },
              "educationalLevel": "Beginner",
              "timeRequired": "PT16H",
              "inLanguage": "es",
              "hasCourseInstance": {
                "@type": "CourseInstance",
                "courseMode": "https://schema.org/MixedEventAttendanceMode",
                "courseWorkload": "PT16H"
              }
            },
            "price": "450",
            "priceCurrency": "EUR",
            "availability": "https://schema.org/InStock",
            "validFrom": "2026-01-01"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Course",
              "name": "Formación Técnica Avanzada en IA",
              "description": "Para equipos técnicos que necesitan implementar soluciones IA. 40 horas intensivas con certificación.",
              "provider": {
                "@id": "https://pymempresas.com/#organization"
              },
              "educationalLevel": "Advanced",
              "timeRequired": "PT40H",
              "inLanguage": "es",
              "coursePrerequisites": "Conocimientos de programación en Python",
              "hasCourseInstance": {
                "@type": "CourseInstance",
                "courseMode": "https://schema.org/MixedEventAttendanceMode",
                "courseWorkload": "PT40H"
              }
            },
            "price": "1200",
            "priceCurrency": "EUR",
            "availability": "https://schema.org/InStock",
            "validFrom": "2026-01-01"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Course",
              "name": "IA para Directivos y Gerentes",
              "description": "Visión estratégica de la IA para la toma de decisiones. Workshop ejecutivo de 8 horas.",
              "provider": {
                "@id": "https://pymempresas.com/#organization"
              },
              "educationalLevel": "Executive",
              "timeRequired": "PT8H",
              "inLanguage": "es",
              "audience": {
                "@type": "EducationalAudience",
                "educationalRole": "manager"
              },
              "hasCourseInstance": {
                "@type": "CourseInstance",
                "courseMode": "https://schema.org/OfflineEventAttendanceMode",
                "courseWorkload": "PT8H"
              }
            },
            "price": "600",
            "priceCurrency": "EUR",
            "availability": "https://schema.org/InStock",
            "validFrom": "2026-01-01"
          }
        ]
      },
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "450",
        "highPrice": "1200",
        "priceCurrency": "EUR",
        "offerCount": "3"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto dura un curso de IA para empresas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La duración varía según el programa: el curso para principiantes dura 16 horas (2 días intensivos o 4 sesiones de 4 horas), la formación técnica avanzada son 40 horas (1 semana intensiva o formato modular), y el workshop para directivos son 8 horas (1 día completo). Adaptamos los horarios a las necesidades de tu empresa."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta la formación en IA para empresas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los precios varían según el programa y el número de participantes. El curso para principiantes desde 450€/persona, la formación técnica avanzada desde 1.200€/persona, y el workshop ejecutivo desde 600€/persona. Ofrecemos descuentos para grupos y podemos diseñar programas a medida."
          }
        },
        {
          "@type": "Question",
          "name": "¿La formación es presencial u online?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ofrecemos las tres modalidades: presencial en tus oficinas en Gijón o Asturias, online en directo con interacción completa, o formato híbrido combinando ambas opciones. La formación presencial permite práctica hands-on más efectiva, mientras que el formato online ofrece mayor flexibilidad horaria."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué nivel previo necesitan los empleados?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Para el curso de principiantes no se requiere experiencia técnica previa, solo conocimientos básicos de informática. La formación técnica avanzada está dirigida a equipos con conocimientos de programación (Python preferiblemente). El workshop para directivos no requiere conocimientos técnicos, solo visión estratégica de negocio."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se obtiene certificación al finalizar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, todos nuestros cursos incluyen certificado de asistencia y aprovechamiento. Para la formación técnica avanzada, los participantes también reciben un certificado de competencias en IA aplicada a negocios. Además, proporcionamos material didáctico y acceso a recursos complementarios durante 6 meses."
          }
        },
        {
          "@type": "Question",
          "name": "¿Por qué fracasan el 85% de los proyectos de IA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La falta de formación es la principal causa. Las empresas invierten en tecnología pero no capacitan a sus equipos, generando resistencia al cambio, uso ineficiente de herramientas y proyectos abandonados. Nuestra formación reduce estos riesgos al 10%, garantizando que tu inversión en IA tenga retorno real y sostenible en el tiempo."
          }
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://pymempresas.com/#localbusiness",
      "name": "PYMEMPRESAS - Formación en IA",
      "image": "https://pymempresas.com/images/logo-header.webp",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "C. Rodríguez San Pedro, 1, Centro",
        "addressLocality": "Gijón",
        "addressRegion": "Asturias",
        "postalCode": "33206",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "43.5453",
        "longitude": "-5.6619"
      },
      "url": "https://pymempresas.com/formacion-ia-empresas/",
      "email": "info@pymempresas.com",
      "priceRange": "450€ - 1200€",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "18:00"
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://pymempresas.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Servicios",
          "item": "https://pymempresas.com/#servicios"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Formación en IA",
          "item": "https://pymempresas.com/formacion-ia-empresas/"
        }
      ]
    }
  ]
};
---

<BaseLayout
  metaTitle="Formación en IA para Empresas en Gijón | PYMEMPRESAS"
  metaDescription="Capacita a tu equipo con cursos prácticos de IA en Gijón y Asturias. Aumenta la productividad hasta un 40% con formación especializada en inteligencia artificial."
  canonicalURL="https://pymempresas.com/formacion-ia-empresas/"
  schema={schema}
>

  <!-- ============================================
       SECCIÓN HERO IA - FORMACIÓN
       ============================================ -->
  <section class="ia-hero-section hero-dark">
    <div class="ia-hero-container">
      <div class="ia-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
          <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
        </svg>
        <span>Upskilling & Reskilling en IA</span>
      </div>
      <h1 class="ia-hero-title">
        Formación en Inteligencia<br>Artificial para Empresas en Gijón
      </h1>
      <p class="ia-hero-description">
        Capacita a tu equipo con cursos prácticos de IA. Aumenta la productividad y mantén tu empresa competitiva en la era de la inteligencia artificial.
      </p>
      <div class="ia-hero-buttons">
        <a href="#contacto" class="ia-btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          Solicitar Programa Formativo
        </a>
        <a href="#cursos" class="ia-btn-secondary">
          Ver Cursos Disponibles
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECCIÓN POR QUÉ FORMAR EN IA
       ============================================ -->
  <section class="ia-benefits-section">
    <div class="ia-benefits-container">
      <div class="ia-benefits-header">
        <h2 class="ia-benefits-title">¿Por qué formar a tu equipo en IA?</h2>
        <p class="ia-benefits-subtitle">
          El <strong>85% de los proyectos de IA fracasan</strong> por falta de formación adecuada. Invertir en capacitación es la clave para una implementación exitosa y un retorno real de la inversión.
        </p>
      </div>

      <div class="ia-risk-solution" style="margin-bottom: 50px; background: #FEF2F2; border: 1px solid #FEE2E2; max-width: 900px; margin-left: auto; margin-right: auto;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #DC2626; min-width: 24px;">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <div>
          <strong style="color: #1a1a1a; display: block; margin-bottom: 8px;">El coste de NO formar a tu equipo</strong>
          <span style="color: #666;">Empresas que implementan IA sin formación previa experimentan resistencia al cambio, uso ineficiente de herramientas y proyectos abandonados. La formación reduce estos riesgos y acelera la adopción tecnológica.</span>
        </div>
      </div>

      <div class="ia-benefits-grid">
        <div class="ia-benefit-card">
          <div class="ia-benefit-icon" style="background: #FFF8E8;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="19 6 12 5 5 6"></polyline>
              <polyline points="5 18 12 19 19 18"></polyline>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Aumento de Productividad</h3>
          <p class="ia-benefit-description">Los equipos formados en IA son hasta un 40% más productivos en tareas rutinarias</p>
        </div>

        <div class="ia-benefit-card">
          <div class="ia-benefit-icon" style="background: #FFF8E8;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="6"></circle>
              <circle cx="12" cy="12" r="2"></circle>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Reducción de Errores</h3>
          <p class="ia-benefit-description">La automatización inteligente elimina errores humanos en procesos repetitivos</p>
        </div>

        <div class="ia-benefit-card">
          <div class="ia-benefit-icon" style="background: #FFF8E8;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Ventaja Competitiva</h3>
          <p class="ia-benefit-description">Empresas con equipos formados en IA lideran la transformación digital en Asturias</p>
        </div>

        <div class="ia-benefit-card">
          <div class="ia-benefit-icon" style="background: #FFF8E8;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623;">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Retención de Talento</h3>
          <p class="ia-benefit-description">Los empleados valoran empresas que invierten en su desarrollo profesional</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECCIÓN NUESTROS CURSOS DE IA
       ============================================ -->
  <section class="ia-services-section" id="cursos">
    <div class="ia-services-container">
      <div class="ia-services-header">
        <h2 class="ia-services-title">Nuestros Cursos de IA para Negocios en Asturias</h2>
        <p class="ia-services-subtitle">Programas formativos adaptados a diferentes perfiles profesionales, desde empleados sin experiencia técnica hasta equipos de desarrollo.</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px;">
        <!-- Curso 1: Principiantes -->
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
          <div style="width: 60px; height: 60px; background: #F5F5F5; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #666;">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <h3 style="font-size: 22px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.3;">Curso de IA para Principiantes</h3>
          <p style="font-size: 15px; line-height: 1.6; color: #666; margin: 0;">Formación introductoria ideal para empleados sin experiencia técnica</p>
          <div style="display: flex; gap: 15px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 6px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #666;">
                <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span style="font-size: 14px; color: #666;">16 horas</span>
            </div>
            <div style="display: flex; align-items: center; gap: 6px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #666;">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <span style="font-size: 14px; color: #666;">Presencial / Online</span>
            </div>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Fundamentos de la Inteligencia Artificial</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Uso práctico de ChatGPT y herramientas IA</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Automatización de tareas cotidianas</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #666;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #F5A623; min-width: 18px; margin-top: 2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Ética y limitaciones de la IA</span>
            </li>
          </ul>
          <a href="#contacto" style="margin-top: auto; text-align: center; display: block; padding: 14px 28px; color: #1a1a1a; background: transparent; border: 2px solid #1a1a1a; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 15px; transition: all 0.3s ease;">Más Información</a>
        </div>

        <!-- Curso 2: Formación Técnica Avanzada -->
        <div style="background: #ffffff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 35px 30px; display: flex; flex-direction: column; gap: 20px; transition: all 0.3s ease;">
