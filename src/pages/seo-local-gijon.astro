@media (max-width: 480px) {
  .seo-title {
    font-size: 1.8rem;
  }

  .advantages-title {
    font-size: 1.6rem;
  }

  .seo-faq-title {
    font-size: 1.6rem;
  }

  .seo-faq-question {
    padding: 16px;
    gap: 10px;
    font-size: 0.9rem;
  }

  .seo-faq-answer p {
    padding: 0 16px 16px 16px;
    padding-left: 44px;
  }

  .seo-faq-icon,
  .seo-faq-chevron {
    width: 18px;
    height: 18px;
    min-width: 18px;
  }
}
