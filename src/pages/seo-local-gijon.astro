  }

  .seo-content-grid-new {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .expert-tasks-grid {
    grid-template-columns: 1fr;
  }

  .about-pymempresas,
  .advantages-pymempresas,
  .pricing-section,
  .seo-faq-section {
    padding: 60px 0;
  }

  .advantages-container {
    padding: 0 16px;
  }

  .seo-faq-section {
    padding: 60px 15px;
  }

  .seo-faq-title {
    font-size: 1.9rem;
  }

  .seo-faq-subtitle {
    font-size: 1rem;
  }

  .seo-faq-question {
    padding: 20px;
    font-size: 0.95rem;
    gap: 12px;
  }

  .seo-faq-answer p {
    padding: 0 20px 20px 20px;
    padding-left: 52px;
    font-size: 0.9rem;
  }

  .benefits-grid {
    grid-template-columns: 1fr;
  }

  .seo-types-grid {
    grid-template-columns: 1fr;
  }

  .seo-local-featured::before {
    display: none;
  }

  .pricing-card {
    padding: 28px 20px;
  }

  .price-amount {
    font-size: 2.6rem;
  }
