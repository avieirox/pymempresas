/* --- FAQ SECTION --- */
.seo-faq-section {
  padding: 80px 20px;
  background: #111111;
}

.seo-faq-container {
  max-width: 900px;
  margin: 0 auto;
}

.seo-faq-header {
  text-align: center;
  margin-bottom: 50px;
}

.seo-faq-title {
  font-size: 2.5rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 15px;
  line-height: 1.2;
}

.seo-faq-subtitle {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.6);
  max-width: 750px;
  margin: 0 auto;
  line-height: 1.6;
}

.seo-faq-accordion {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.seo-faq-item {
  background: #1a1a2e;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  overflow: hidden;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.seo-faq-item:hover {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  transform: translateY(-2px);
  border-color: rgba(245, 166, 35, 0.15);
}

.seo-faq-question {
  width: 100%;
  padding: 24px 28px;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  gap: 16px;
  cursor: pointer;
  text-align: left;
  font-size: 1.05rem;
  font-weight: 600;
  color: #ffffff;
  transition: all 0.3s ease;
}

.seo-faq-question:hover {
  color: #F5A623;
}

.seo-faq-icon {
  flex-shrink: 0;
  color: #F5A623;
  min-width: 20px;
}

.seo-faq-question span {
  flex: 1;
}

.seo-faq-chevron {
  flex-shrink: 0;
  transition: transform 0.3s ease;
  color: rgba(255, 255, 255, 0.5);
  min-width: 20px;
}

.seo-faq-item.active {
  background: #1a1a2e;
  border-color: rgba(245, 166, 35, 0.25);
}

.seo-faq-item.active .seo-faq-chevron {
  transform: rotate(180deg);
  color: #F5A623;
}

.seo-faq-item.active .seo-faq-question {
  color: #F5A623;
}

.seo-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
  background: transparent;
}

.seo-faq-answer p {
  padding: 0 28px 24px 28px;
  margin: 0;
  color: rgba(255, 255, 255, 0.65);
  font-size: 1rem;
  line-height: 1.7;
  padding-left: 64px;
}

/* --- RESPONSIVE --- */
@media (max-width: 1024px) {
  .seo-types-grid {
    grid-template-columns: repeat(2, 1fr);
  }

