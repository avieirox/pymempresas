        <!-- Servicio 4: IA Generativa -->
        <div class="ia-service-card">
          <div class="ia-service-header">
            <div class="ia-service-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <div>
              <h3 class="ia-service-title">IA Generativa para Marketing</h3>
              <p class="ia-service-description">Crea contenido, im&aacute;genes y campa&ntilde;as con herramientas de IA generativa.</p>
            </div>
          </div>
          <ul class="ia-service-features">
            <li>Generaci&oacute;n de textos</li>
            <li>Creaci&oacute;n de im&aacute;genes</li>
            <li>Personalizaci&oacute;n masiva</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION COMPARATIVA HERRAMIENTAS IA -->
  <section class="ia-comparison-section">
    <div class="ia-comparison-container">
      <!-- Encabezado -->
      <div class="ia-comparison-header">
        <h2 class="ia-comparison-title">Mejores herramientas de IA para negocios: ChatGPT vs Copilot</h2>
        <p class="ia-comparison-subtitle">Comparativa de las principales herramientas de IA disponibles para empresas. Te ayudamos a elegir la m&aacute;s adecuada para tu negocio en Gij&oacute;n.</p>
      </div>

      <!-- Tabla comparativa -->
      <div class="ia-comparison-table-wrapper">
        <table class="ia-comparison-table">
          <thead>
            <tr>
              <th>Herramienta</th>
              <th>Tipo</th>
              <th>Mejor para</th>
              <th>Precio</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>ChatGPT / GPT-4</strong></td>
              <td><span class="ia-tag">IA Conversacional</span></td>
              <td>Redacci&oacute;n, an&aacute;lisis, programaci&oacute;n</td>
              <td><strong>Desde 20&euro;/mes</strong></td>
            </tr>
            <tr>
              <td><strong>Microsoft Copilot</strong></td>
              <td><span class="ia-tag">Productividad Empresarial</span></td>
              <td>Office 365, automatizaci&oacute;n</td>
              <td><strong>Desde 28&euro;/usuario/mes</strong></td>
            </tr>
            <tr>
              <td><strong>Claude AI</strong></td>
              <td><span class="ia-tag">IA Conversacional</span></td>
              <td>An&aacute;lisis de documentos largos</td>
              <td><strong>Desde 18&euro;/mes</strong></td>
            </tr>
            <tr>
              <td><strong>Gemini Pro</strong></td>
              <td><span class="ia-tag">IA Multimodal</span></td>
              <td>An&aacute;lisis de im&aacute;genes, datos complejos</td>
              <td><strong>Desde 19&euro;/mes</strong></td>
            </tr>
            <tr>
              <td><strong>Midjourney / DALL-E</strong></td>
              <td><span class="ia-tag">IA Generativa Visual</span></td>
              <td>Creaci&oacute;n de im&aacute;genes y dise&ntilde;o</td>
              <td><strong>Desde 10&euro;/mes</strong></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- CTA inferior -->
      <div class="ia-comparison-cta">
        <p><strong>&iquest;No sabes cu&aacute;l elegir?</strong> Te asesoramos gratuitamente sobre qu&eacute; herramientas de IA se adaptan mejor a las necesidades espec&iacute;ficas de tu empresa en Gij&oacute;n.</p>
      </div>
    </div>
  </section>

  <!-- SECCION RIESGOS Y DESAFIOS IA -->
  <section class="ia-risks-section">
    <div class="ia-risks-container">
      <!-- Encabezado -->
      <div class="ia-risks-header">
        <h2 class="ia-risks-title">Riesgos y desaf&iacute;os de la IA en las empresas</h2>
        <p class="ia-risks-subtitle">La implementaci&oacute;n de IA conlleva riesgos que deben gestionarse correctamente. Te ayudamos a mitigarlos desde el primer momento.</p>
      </div>

      <!-- Grid de riesgos -->
      <div class="ia-risks-grid">
        <!-- Riesgo 1: Privacidad -->
        <div class="ia-risk-card">
          <div class="ia-risk-header">
            <svg class="ia-risk-icon-warning" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <h3 class="ia-risk-title">Privacidad de Datos</h3>
          </div>
          <p class="ia-risk-description">Los datos empresariales sensibles pueden quedar expuestos si no se configuran correctamente las herramientas de IA.</p>

          <div class="ia-risk-solution">
            <svg class="ia-risk-icon-shield" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <div>
              <strong>Nuestra soluci&oacute;n:</strong> Implementamos protocolos de seguridad y usamos soluciones on-premise cuando es necesario.
            </div>
          </div>
        </div>

        <!-- Riesgo 2: Dependencia Tecnol&oacute;gica -->
        <div class="ia-risk-card">
          <div class="ia-risk-header">
            <svg class="ia-risk-icon-warning" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <h3 class="ia-risk-title">Dependencia Tecnol&oacute;gica</h3>
          </div>
          <p class="ia-risk-description">Una excesiva dependencia de la IA puede generar problemas si los sistemas fallan.</p>

          <div class="ia-risk-solution">
            <svg class="ia-risk-icon-shield" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <div>
              <strong>Nuestra soluci&oacute;n:</strong> Dise&ntilde;amos sistemas con redundancia y planes de contingencia.
            </div>
          </div>
        </div>

        <!-- Riesgo 3: Sesgos en Algoritmos -->
        <div class="ia-risk-card">
          <div class="ia-risk-header">
            <svg class="ia-risk-icon-warning" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <h3 class="ia-risk-title">Sesgos en los Algoritmos</h3>
