  }
  `}></script>

  <!-- SECCION IA HERO -->
  <section class="ia-hero-section">
    <div class="ia-hero-container">
      <!-- Badge superior -->
      <div class="ia-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        <span>Consultor&iacute;a IA en Gij&oacute;n</span>
      </div>

      <!-- T&iacute;tulo principal -->
      <h1 class="ia-hero-title">
        Inteligencia Artificial para Empresas en Gij&oacute;n: Soluciones y Consultor&iacute;a
      </h1>

      <!-- Descripci&oacute;n -->
      <p class="ia-hero-description">
        Transforma tu negocio con IA. Automatiza procesos, mejora la productividad y toma decisiones m&aacute;s inteligentes con nuestras soluciones de Inteligencia Artificial adaptadas a empresas de Gij&oacute;n y Asturias.
      </p>

      <!-- Botones CTA -->
      <div class="ia-hero-buttons">
        <a href="#contacto" class="ia-btn-primary">Solicitar Diagn&oacute;stico Gratis</a>
        <a href="#casos-exito" class="ia-btn-secondary">Ver Casos de &Eacute;xito</a>
      </div>
    </div>
  </section>

  <!-- SECCION BENEFICIOS IA -->
  <section class="ia-benefits-section">
    <div class="ia-benefits-container">
      <!-- Encabezado -->
      <div class="ia-benefits-header">
        <h2 class="ia-benefits-title">&iquest;C&oacute;mo puede la Inteligencia Artificial ayudar a las empresas de Gij&oacute;n?</h2>
        <p class="ia-benefits-subtitle">La IA no es solo para grandes corporaciones. Las PYMEs de Gij&oacute;n pueden aprovechar estas tecnolog&iacute;as para competir con ventaja en el mercado local y nacional.</p>
      </div>

      <!-- Grid de beneficios -->
      <div class="ia-benefits-grid">
        <!-- Beneficio 1 -->
        <div class="ia-benefit-card">
          <div class="ia-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Automatizaci&oacute;n de Procesos</h3>
          <p class="ia-benefit-description">Reduce tareas repetitivas y libera tiempo para lo que realmente importa en tu negocio.</p>
        </div>

        <!-- Beneficio 2 -->
        <div class="ia-benefit-card">
          <div class="ia-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Aumento de Productividad</h3>
          <p class="ia-benefit-description">Incrementa la eficiencia operativa hasta un 40% con soluciones de IA personalizadas.</p>
        </div>

        <!-- Beneficio 3 -->
        <div class="ia-benefit-card">
          <div class="ia-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <h3 class="ia-benefit-title">An&aacute;lisis de Datos Avanzado</h3>
          <p class="ia-benefit-description">Toma decisiones basadas en datos con insights que antes eran imposibles de obtener.</p>
        </div>

        <!-- Beneficio 4 -->
        <div class="ia-benefit-card">
          <div class="ia-benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="ia-benefit-title">Atenci&oacute;n al Cliente 24/7</h3>
          <p class="ia-benefit-description">Chatbots inteligentes que atienden a tus clientes en cualquier momento.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION SERVICIOS IA -->
  <section class="ia-services-section">
    <div class="ia-services-container">
      <!-- Encabezado -->
      <div class="ia-services-header">
        <h2 class="ia-services-title">Servicios de implementaci&oacute;n de IA en tu negocio</h2>
        <p class="ia-services-subtitle">Te ayudamos a integrar la Inteligencia Artificial en tu empresa de forma pr&aacute;ctica, empezando por las &aacute;reas donde generar&aacute; mayor impacto.</p>
      </div>

      <!-- Grid de servicios -->
      <div class="ia-services-grid">
        <!-- Servicio 1: Chatbots -->
        <div class="ia-service-card">
          <div class="ia-service-header">
            <div class="ia-service-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="ia-service-title">Chatbots y Asistentes Virtuales</h3>
              <p class="ia-service-description">Implementaci&oacute;n de chatbots inteligentes para atenci&oacute;n al cliente, ventas y soporte t&eacute;cnico.</p>
            </div>
          </div>
          <ul class="ia-service-features">
            <li>Integraci&oacute;n con WhatsApp</li>
            <li>Respuestas personalizadas</li>
            <li>Escalado a humanos</li>
          </ul>
        </div>

        <!-- Servicio 2: Automatizaci&oacute;n -->
        <div class="ia-service-card">
          <div class="ia-service-header">
            <div class="ia-service-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M9 9h6v6H9z"/>
              </svg>
            </div>
            <div>
              <h3 class="ia-service-title">Automatizaci&oacute;n con IA</h3>
              <p class="ia-service-description">Automatiza procesos empresariales repetitivos con flujos de trabajo inteligentes.</p>
            </div>
          </div>
          <ul class="ia-service-features">
            <li>Procesamiento de documentos</li>
            <li>Gesti&oacute;n de emails</li>
            <li>Flujos autom&aacute;ticos</li>
          </ul>
        </div>

        <!-- Servicio 3: An&aacute;lisis Predictivo -->
        <div class="ia-service-card">
          <div class="ia-service-header">
            <div class="ia-service-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6" y1="20" x2="6" y2="14"/>
              </svg>
            </div>
            <div>
              <h3 class="ia-service-title">An&aacute;lisis Predictivo</h3>
              <p class="ia-service-description">Anticipa tendencias y comportamientos con modelos de machine learning.</p>
            </div>
          </div>
          <ul class="ia-service-features">
            <li>Predicci&oacute;n de ventas</li>
            <li>An&aacute;lisis de clientes</li>
            <li>Detecci&oacute;n de anomal&iacute;as</li>
