              "priceSpecification": {
                "@type": "PriceSpecification",
                "priceCurrency": "EUR",
                "price": "500-2000",
                "valueAddedTaxIncluded": false
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Automatización de Procesos con IA",
                "description": "Automatización de procesos empresariales repetitivos con flujos de trabajo inteligentes, procesamiento de documentos y gestión automatizada de emails.",
                "image": "/images/pymempresas-logo.png"
              },
              "priceSpecification": {
                "@type": "PriceSpecification",
                "priceCurrency": "EUR",
                "price": "500-2000",
                "valueAddedTaxIncluded": false
              }
