          "https://schema.org/ComputerRepair"
        ],
        "audience": {
          "@type": "Audience",
          "audienceType": "PYMEs y empresas en Gijón y Asturias"
        }
      },
      {
        "@type": "FAQPage",
        "@id": "https://pymempresas.com/inteligencia-artificial-empresas/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Cuál es la mejor IA gratuita para empezar?",
