>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={`
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "@id": "https://pymempresas.com/inteligencia-artificial-empresas/#service",
        "name": "Inteligencia Artificial para Empresas en Gijón",
        "description": "Servicios de consultoría e implementación de Inteligencia Artificial para empresas en Gijón y Asturias. Automatización de procesos, chatbots, análisis predictivo y soluciones de IA generativa.",
        "url": "https://pymempresas.com/inteligencia-artificial-empresas/",
        "image": "/images/pymempresas-logo.png",
