              "@type": "AdministrativeArea",
              "name": "Asturias"
            }
          }
        },
        "serviceType": "Consultoría e Implementación de Inteligencia Artificial",
        "areaServed": [
          {
            "@type": "City",
            "name": "Gijón"
          },
          {
            "@type": "AdministrativeArea",
            "name": "Asturias"
          }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios de Inteligencia Artificial",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Chatbots y Asistentes Virtuales con IA",
                "description": "Implementación de chatbots inteligentes para atención al cliente, ventas y soporte técnico con integración WhatsApp y respuestas personalizadas.",
