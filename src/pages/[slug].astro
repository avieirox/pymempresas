---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ReadingProgress from '../components/blog/ReadingProgress.astro';
import ArticleHero from '../components/blog/ArticleHero.astro';
import ArticleBody from '../components/blog/ArticleBody.astro';
import ShareRow from '../components/blog/ShareRow.astro';
import RelatedArticles from '../components/blog/RelatedArticles.astro';
import { SITE } from '../lib/constants';

export async function getStaticPaths() {
  const blog = await getCollection('blog');
  return blog.map((b) => ({
    params: { slug: b.slug },
    props: { entry: b },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content: Body } = await entry.render();

const pageTitle = data.title;
const pageDescription = data.description;

const blogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${SITE.url}/${entry.slug}/#article`,
      headline: data.title,
      description: data.description,
      image: data.image ? `${SITE.url}${data.image}` : undefined,
      datePublished: data.date?.toISOString(),
      dateModified: data.date?.toISOString(),
      author: {
        '@type': 'Person',
        name: data.author,
        ...(data.authorLinkedin ? { sameAs: data.authorLinkedin } : {}),
        ...(data.authorImage ? { image: `${SITE.url}${data.authorImage}` } : {}),
        ...(data.authorBio ? { description: data.authorBio } : {}),
      },
      publisher: {
        '@type': 'Organization',
        '@id': `${SITE.url}/#business`,
        name: SITE.name,
        url: SITE.url,
        logo: { '@type': 'ImageObject', url: `${SITE.url}/images/logo-header.webp` },
      },
      mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE.url}/${entry.slug}/` },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog/` },
        { '@type': 'ListItem', position: 3, name: data.title },
      ],
    },
  ],
};
---

<BaseLayout
  metaTitle={pageTitle}
  metaDescription={pageDescription}
  ogImage={data.image || data.ogImage}
  ogType="article"
  canonicalURL={new URL(`/${entry.slug}/`, Astro.site).href}
  schema={blogSchema}
  bodyTheme="light"
>
  <ReadingProgress />
  <ArticleHero
    title={data.title}
    slug={entry.slug}
    image={data.image}
    tags={data.tags}
    date={data.date ?? new Date()}
    author={data.author ?? 'PYMEMPRESAS'}
    authorImage={data.authorImage}
  />
  <div class="bg-white">
    <section class="section" style="padding-top:0;padding-bottom:40px;">
      <div class="container" style="max-width:800px;">
        <Breadcrumbs
          items={[
            { label: 'Inicio', href: '/' },
            { label: 'Blog', href: '/blog/' },
            { label: data.title },
          ]}
        />
      </div>
    </section>
    <ArticleBody>
      <Body />
    </ArticleBody>
    <ShareRow
      url={new URL(`/${entry.slug}/`, Astro.site).href}
      title={data.title}
      author={data.author}
      authorBio={data.authorBio}
      authorLinkedin={data.authorLinkedin}
      authorTwitter={data.authorTwitter}
      authorImage={data.authorImage}
    />
  </div>
  <RelatedArticles
    currentSlug={entry.slug}
    currentTags={data.tags ?? []}
  />
  <FinalCTA />
</BaseLayout>
