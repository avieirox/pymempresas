---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://pymempresas.com/posicionamiento-web-asturias/#service",
      "serviceType": "Posicionamiento Web SEO + LLM",
      "name": "Posicionamiento en Buscadores y LLMs",
      "alternateName": ["SEO + GEO", "Optimización para Buscadores e IA Generativa"],
      "description": "Servicio integral de posicionamiento web que combina SEO tradicional con optimización para Large Language Models (LLMs). Aparece tanto en Google como en ChatGPT, Perplexity, Claude y otros asistentes de IA.",
      "url": "https://pymempresas.com/posicionamiento-web-asturias/",
      "provider": {
        "@id": "https://pymempresas.com/#organization"
      },
      "areaServed": [
        { "@type": "City", "name": "Gijón" },
        { "@type": "City", "name": "Oviedo" },
        { "@type": "City", "name": "Avilés" },
        { "@type": "City", "name": "Siero" },
        { "@type": "City", "name": "Langreo" },
        { "@type": "AdministrativeArea", "name": "Asturias" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Planes de Posicionamiento SEO + LLM",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Plan Esencial - SEO + LLM",
              "description": "Ideal para iniciar tu presencia en buscadores y LLMs. Incluye auditoría inicial, optimización SEO básica, configuración Schema.org, monitorización de menciones en IA y 10 palabras clave objetivo."
            },
            "price": "397",
            "priceCurrency": "EUR",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "397",
              "priceCurrency": "EUR",
              "unitText": "MONTH"
            },
            "availability": "https://schema.org/InStock",
            "url": "https://pymempresas.com/posicionamiento-web-asturias/#precios"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Plan Profesional - SEO + LLM",
              "description": "Domina tanto buscadores tradicionales como IA. Incluye todo del plan Esencial más GEO y AEO avanzado, 25 palabras clave, optimización para ChatGPT/Perplexity, contenido optimizado para LLMs y link building mensual."
            },
            "price": "697",
            "priceCurrency": "EUR",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "697",
              "priceCurrency": "EUR",
              "unitText": "MONTH"
            },
            "availability": "https://schema.org/InStock",
            "url": "https://pymempresas.com/posicionamiento-web-asturias/#precios"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Plan Enterprise - SEO + LLM",
              "description": "Liderazgo total en visibilidad digital. Incluye todo del plan Profesional más palabras clave ilimitadas, estrategia multicanal completa, consultor dedicado y reuniones semanales."
            },
            "price": "1197",
            "priceCurrency": "EUR",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "1197",
              "priceCurrency": "EUR",
              "unitText": "MONTH"
            },
            "availability": "https://schema.org/InStock",
            "url": "https://pymempresas.com/posicionamiento-web-asturias/#precios"
          }
        ]
      },
      "additionalType": [
        "https://schema.org/SearchEngineOptimization",
        "https://schema.org/MarketingService"
      ],
      "category": [
        "SEO Tradicional",
        "GEO (Generative Engine Optimization)",
        "AEO (Answer Engine Optimization)",
        "LLM Optimization",
        "Link Building",
        "Gestión de Reseñas"
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://pymempresas.com/posicionamiento-web-asturias/#webpage",
      "url": "https://pymempresas.com/posicionamiento-web-asturias/",
      "name": "Posicionamiento Web SEO + LLM | Aparece en Google y ChatGPT | PYMEMPRESAS",
      "description": "Posicionamiento web en Asturias que combina SEO tradicional con optimización para LLMs. Aparece en Google, ChatGPT, Perplexity y Claude. Desde 397€/mes.",
      "inLanguage": "es-ES",
      "isPartOf": {
        "@id": "https://pymempresas.com/#website"
      },
      "about": {
        "@id": "https://pymempresas.com/posicionamiento-web-asturias/#service"
      },
      "breadcrumb": {
        "@id": "https://pymempresas.com/posicionamiento-web-asturias/#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://pymempresas.com/posicionamiento-web-asturias/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://pymempresas.com/" },
        { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://pymempresas.com/servicios/" },
        { "@type": "ListItem", "position": 3, "name": "Posicionamiento Web + LLM", "item": "https://pymempresas.com/posicionamiento-web-asturias/" }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://pymempresas.com/posicionamiento-web-asturias/#faqpage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué diferencia hay entre SEO tradicional y optimización para LLMs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El SEO tradicional optimiza para algoritmos de ranking de buscadores como Google. La optimización para LLMs (GEO) se enfoca en que los modelos de lenguaje como ChatGPT o Perplexity mencionen y recomienden tu marca cuando los usuarios hacen consultas. Ambas estrategias son complementarias y necesarias en 2024."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo sé si ChatGPT o Perplexity mencionan mi empresa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Realizamos auditorías periódicas preguntando a los principales LLMs sobre tu sector, servicios y competidores. Monitorizamos si tu marca aparece en las respuestas y en qué contexto, comparándolo con la competencia."
          }
        },
        {
          "@type": "Question",
          "name": "¿Puedo aparecer en las respuestas de ChatGPT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, aunque no es tan directo como el SEO tradicional. Los LLMs aprenden de contenido web público, por lo que optimizar tu contenido con datos estructurados, información verificable y autoridad de marca aumenta las probabilidades de ser citado."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es el Link Building y por qué es importante?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El Link Building es la estrategia de conseguir enlaces desde otros sitios web hacia el tuyo. Estos enlaces actúan como 'votos de confianza' que mejoran tu autoridad ante Google y los LLMs. Un buen perfil de enlaces es fundamental para posicionar en búsquedas competitivas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo conseguís enlaces de calidad para mi web?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Utilizamos estrategias éticas y sostenibles: guest posting en medios relevantes, digital PR, colaboraciones con empresas complementarias, directorios de calidad y conversión de menciones sin enlace. Nunca compramos enlaces de baja calidad que puedan penalizar tu web."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo puedo conseguir más reseñas de clientes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Implementamos un sistema automatizado de solicitud de reseñas que contacta a tus clientes en el momento óptimo. También te proporcionamos plantillas, QR codes y estrategias para facilitar que tus clientes satisfechos dejen su opinión."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué hago con las reseñas negativas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Las reseñas negativas son oportunidades de mejora. Te asesoramos en cómo responder profesionalmente, resolver el problema públicamente y convertir una experiencia negativa en una demostración de tu compromiso con el cliente. Nunca recomendamos eliminar o ignorar reseñas legítimas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda en verse resultados?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En SEO tradicional y link building, los primeros resultados suelen verse en 3-6 meses. Las reseñas tienen impacto más inmediato en la conversión. Para LLMs, el proceso puede ser más variable ya que depende de cuándo los modelos actualizan su conocimiento."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es GEO (Generative Engine Optimization)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "GEO es la disciplina de optimizar contenido para que sea seleccionado y citado por motores de IA generativa. Incluye técnicas como datos estructurados, contenido verificable, citas de fuentes autorizadas y formato de respuesta directa."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  metaTitle="Posicionamiento Web SEO + LLM | Aparece en Google y ChatGPT | PYMEMPRESAS"
  metaDescription="Posicionamiento web en Asturias que combina SEO tradicional con optimización para LLMs. Aparece en Google, ChatGPT, Perplexity y Claude. Desde 397€/mes."
  canonicalURL="https://pymempresas.com/posicionamiento-web-asturias/"
  schema={schema}
>
  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO SECTION -->
  <div class="hero-pymempresas-wrapper">
    <div class="hero-pymempresas seo-hero-light">
      <div class="hero-content hero-content-center">
        <div class="hero-badge seo-badge">
          <svg class="hero-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
          <span>SEO + LLMs: El futuro del posicionamiento</span>
        </div>

        <h1 class="hero-title seo-title">Posicionamiento WEB en <span class="text-highlight">Buscadores e IA en Asturias</span></h1>

        <p class="hero-subtitle seo-subtitle">Si un negocio no aparece en Google o en la IA cuando lo buscan, no tiene un problema de visibilidad. Tiene un problema de clientes que se van a otro. Este <strong>servicio de posicionamiento web en Asturias</strong> se centra en eso: aparecer donde hoy se decide la compra. Google, ChatGPT, Perplexity, Gemini y Claude. SEO, link building y gestión de reseñas orientados a tu zona de acción y a quien ya está listo para llamar. No hay discursos ni promesas vacías. Hay una estrategia clara: que te encuentren, confíen y contacten. Y si no se puede hacer bien, se dice antes.Asesoramiento y ejecución de SEO, Link Building y Gestión de Reseñas.</p>

        <div class="hero-buttons">
          <a href="#contacto" class="hero-btn-primary seo-btn-primary">Auditoría Gratis SEO + LLM</a>
          <a href="#precios" class="hero-btn-secondary seo-btn-secondary">Ver Precios</a>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION: Aparecer en los Buscadores Ya no es lo que era -->
  <section class="advantages-pymempresas">
    <div class="advantages-container">
      <div class="advantages-header">
        <h2 class="advantages-title">Aparecer en los Buscadores <span class="text-highlight">Ya no es lo que era</span></h2>
        <p class="advantages-subtitle">Ya no basta con aparecer en Google. Los usuarios cada vez más consultan a ChatGPT, Perplexity y otros LLMs para tomar decisiones.</p>
      </div>

      <div class="paradigm-grid">
        <div class="paradigm-text">
          <p class="paradigm-paragraph"><strong>El 40% de los usuarios</strong> ya utilizan asistentes de IA para buscar información, recomendaciones y tomar decisiones de compra. Si tu empresa no aparece en estas respuestas, estás perdiendo clientes.</p>

          <p class="paradigm-paragraph">En <strong>Asturias</strong>, las empresas que se adelanten a esta tendencia dominarán el mercado. Ofrecemos una estrategia integral que combina SEO tradicional con GEO (Generative Engine Optimization).</p>

          <p class="paradigm-paragraph">Nuestro enfoque garantiza que tu marca sea visible tanto cuando alguien busca en Google "mejor [tu servicio] en Gijón" como cuando le pregunta a ChatGPT "¿qué empresa me recomiendas para [tu servicio]?".</p>
        </div>

        <div class="chatgpt-example">
          <div class="chatgpt-header">
            <svg class="chatgpt-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <h3 class="chatgpt-title">Ejemplo en ChatGPT</h3>
          </div>

          <div class="chatgpt-content">
            <p class="chatgpt-user-label">Usuario pregunta:</p>
            <p class="chatgpt-query">"¿Qué agencia de marketing digital me recomiendas en Gijón?"</p>

            <div class="chatgpt-response">
              <div class="response-item">
                <svg class="check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9 12l2 2 4-4"></path>
                </svg>
                <span>Tu empresa aparece en la respuesta</span>
              </div>

              <div class="response-item">
                <svg class="check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9 12l2 2 4-4"></path>
                </svg>
                <span>Se mencionan tus servicios y especialidades</span>
              </div>

              <div class="response-item">
                <svg class="check-icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9 12l2 2 4-4"></path>
                </svg>
                <span>El usuario confía y te contacta</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION: Por Qué Necesitas Posicionamiento Web SEO + IA -->
