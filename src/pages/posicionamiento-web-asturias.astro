<script>
/**
 * FAQ Accordion Toggle
 * Manages open/close states for the SEO FAQ section
 */
window.toggleSEOFAQ = function(button) {
  var item = button.parentElement;
  var answer = item.querySelector('.seo-faq-answer');
  var isActive = item.classList.contains('active');

  // Close other open items
  document.querySelectorAll('.seo-faq-item').forEach(function(otherItem) {
    if (otherItem !== item && otherItem.classList.contains('active')) {
      otherItem.classList.remove('active');
      otherItem.querySelector('.seo-faq-answer').style.maxHeight = null;
    }
  });

  // Toggle current item
  item.classList.toggle('active');

  if (!isActive) {
    answer.style.maxHeight = answer.scrollHeight + 'px';
  } else {
    answer.style.maxHeight = null;
  }
};
</script>
