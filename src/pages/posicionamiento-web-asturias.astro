/* ============================================
   RESPONSIVE
   ============================================ */

@media (max-width: 1200px) {
  .seo-llm-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }
  .positioning-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }
}

@media (max-width: 1024px) {
  .llms-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .pricing-grid {
    grid-template-columns: 1fr;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .pricing-card-featured {
    order: -1;
  }
  .reviews-importance-section {
    padding: 60px 0;
  }
  .reviews-importance-container {
    padding: 0 30px;
  }
  .reviews-importance-card {
    padding: 45px 50px;
  }
  .reviews-stats-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 35px;
  }
}

@media (max-width: 968px) {
