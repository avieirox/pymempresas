/* --- FAQ SECTION --- */
.seo-faq-section {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw !important;
  margin-right: -50vw !important;
  padding: 80px 20px;
  background: #f5f7fa;
}

.seo-faq-container {
  max-width: 900px;
  margin: 0 auto;
}

.seo-faq-header {
  text-align: center;
  margin-bottom: 50px;
}

.seo-faq-title {
  font-size: 2.5rem;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 15px;
  line-height: 1.2;
}

.seo-faq-subtitle {
  font-size: 1.1rem;
  color: #666;
  max-width: 750px;
  margin: 0 auto;
  line-height: 1.6;
}

.seo-faq-accordion {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.seo-faq-item {
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  overflow: hidden;
  transition: all 0.3s ease;
  border: 1px solid rgba(0,0,0,0.05);
}

.seo-faq-item:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  transform: translateY(-2px);
  border-color: rgba(245, 166, 35, 0.2);
}

.seo-faq-question {
  width: 100%;
  padding: 24px 28px;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  gap: 16px;
  cursor: pointer;
  text-align: left;
  font-size: 1.05rem;
  font-weight: 600;
  color: #1a1a1a;
  transition: all 0.3s ease;
}

.seo-faq-question:hover {
  color: #F5A623;
}

.seo-faq-icon {
  flex-shrink: 0;
  color: #F5A623;
  min-width: 20px;
}

.seo-faq-question span {
  flex: 1;
}

.seo-faq-chevron {
  flex-shrink: 0;
  transition: transform 0.3s ease;
  color: #666;
  min-width: 20px;
}

.seo-faq-item.active {
  background: #ffffff;
  border-color: rgba(245, 166, 35, 0.3);
}

.seo-faq-item.active .seo-faq-chevron {
  transform: rotate(180deg);
  color: #F5A623;
}

.seo-faq-item.active .seo-faq-question {
  color: #F5A623;
}

.seo-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
  background: transparent;
}

.seo-faq-answer p {
  padding: 0 28px 24px 64px;
  margin: 0;
  color: #555;
  font-size: 1rem;
  line-height: 1.7;
}

