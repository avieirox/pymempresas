---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://pymempresas.com/google-negocios/#service",
      "serviceType": "Optimización Google Business Profile",
      "name": "Google para Negocios - Perfil de Empresa de Google",
      "description": "Optimización profesional de Google Business Profile (Perfil de Empresa de Google) para negocios en Asturias. Mejora tu visibilidad en Google Maps y en búsquedas locales.",
      "url": "https://pymempresas.com/google-negocios/",
      "provider": {
        "@id": "https://pymempresas.com/#organization"
      },
      "areaServed": [
        { "@type": "City", "name": "Gijón" },
        { "@type": "City", "name": "Oviedo" },
        { "@type": "City", "name": "Avilés" },
        { "@type": "AdministrativeArea", "name": "Asturias" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Planes de Optimización Google Business Profile",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Plan Básico - Perfil de Empresa Google" },
            "price": "297",
            "priceCurrency": "EUR",
            "description": "Optimización básica de Google Business Profile, auditoría inicial y gestión de reseñas."
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Plan Profesional - Perfil de Empresa Google" },
            "price": "497",
            "priceCurrency": "EUR",
            "description": "Optimización completa, estrategia de contenido local y reportes detallados."
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Plan Premium - Perfil de Empresa Google" },
            "price": "897",
            "priceCurrency": "EUR",
            "description": "Estrategia avanzada multi-ciudad con gestión completa y monitorización continua."
          }
        ]
      }
    },
    {
      "@type": "WebPage",
      "@id": "https://pymempresas.com/google-negocios/#webpage",
      "url": "https://pymempresas.com/google-negocios/",
      "name": "Google para Negocios - Optimización de Perfil de Empresa | PYMEMPRESAS",
      "description": "Especialistas en optimizar tu Perfil de Empresa de Google (Google My Business) en Asturias. Aparece en Google Maps y domina las búsquedas locales. Desde 297€/mes.",
      "inLanguage": "es-ES",
      "isPartOf": { "@id": "https://pymempresas.com/#website" },
      "about": { "@id": "https://pymempresas.com/google-negocios/#service" },
      "breadcrumb": { "@id": "https://pymempresas.com/google-negocios/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://pymempresas.com/google-negocios/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://pymempresas.com/" },
        { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://pymempresas.com/servicios/" },
        { "@type": "ListItem", "position": 3, "name": "Google para Negocios", "item": "https://pymempresas.com/google-negocios/" }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://pymempresas.com/google-negocios/#faqpage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué diferencia hay entre SEO normal y SEO local?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El SEO normal se centra en posicionar tu web a nivel nacional o internacional. El SEO Local optimiza tu presencia online para búsquedas con intención geográfica. Incluye optimización de Google Business Profile, directorios locales, reseñas y señales de proximidad."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo tarda en dar resultados el SEO local?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los primeros resultados suelen verse entre 2-4 meses. La optimización de Google Business Profile puede generar resultados en las primeras semanas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Es necesario tener una tienda física para hacer SEO local?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. El SEO local también funciona para negocios con área de servicio que se desplazan al cliente. Puedes configurar tu perfil de Google para mostrar tu zona de cobertura."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué importancia tienen las reseñas en el SEO local?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Las reseñas son uno de los factores más importantes del SEO local. Google las considera como señales de confianza y calidad del servicio. Mejoran tu posicionamiento en el Local Pack y aumentan tu CTR."
          }
        },
        {
          "@type": "Question",
          "name": "¿Puedo hacer SEO local en varias ciudades a la vez?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, es posible y recomendable si tu negocio opera en múltiples ubicaciones. En PYMEMPRESAS trabajamos con negocios en Gijón, Oviedo, Avilés y otras ciudades asturianas simultáneamente."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta el SEO local para mi negocio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nuestros planes comienzan desde 297€/mes. Ofrecemos Básico (297€/mes), Profesional (497€/mes) y Premium (897€/mes). Sin permanencia."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  metaTitle="Google My Business en Asturias — Optimización | PYMEMPRESAS"
  metaDescription="¿Tu negocio no aparece en Google Maps? Lo optimizamos. Más reseñas, más llamadas, más clientes en Gijón y Asturias. Primera consulta gratis."
  canonicalURL="https://pymempresas.com/google-negocios/"
  schema={schema}
  bodyTheme="light"
>

  <!-- SECCION HERO DARK GMB -->
  <div class="hero-pymempresas-wrapper">
    <div class="hero-pymempresas hero-dark-gmb">
      <div class="hero-content hero-content-center">
        <div class="hero-badge hero-badge-dark">
          <svg class="hero-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span>Especialistas en Perfil de Empresa de Google en Asturias</span>
        </div>

        <h1 class="hero-title hero-title-dark">Google para Negocios: Haz que tus clientes <span class="text-highlight-underline">te encuentren primero</span></h1>

        <p class="hero-subtitle hero-subtitle-dark">El 46% de las búsquedas en Google tienen intención local. Si no apareces cuando te buscan en tu ciudad, estás perdiendo clientes cada día. Posiciona tu negocio en Gijón, Oviedo o Avilés.</p>

        <div class="hero-buttons hero-buttons-center">
          <a href="/consultoria/" class="hero-btn-primary">Auditoría SEO Local Gratis →</a>
          <a href="#casos" class="hero-btn-secondary hero-btn-secondary-dark">Ver Casos de Éxito</a>
        </div>

        <div class="hero-stats-dark">
          <div class="hero-stat-dark">
            <div class="stat-number-dark">46%</div>
            <p class="stat-text-dark">de todas las búsquedas en Google tienen intención local</p>
          </div>
          <div class="hero-stat-dark">
            <div class="stat-number-dark">88%</div>
            <p class="stat-text-dark">de los consumidores que buscan negocios locales llaman o visitan en 24h</p>
          </div>
          <div class="hero-stat-dark">
            <div class="stat-number-dark">72%</div>
            <p class="stat-text-dark">de los consumidores que hacen búsqueda local visitan una tienda en 8km</p>
          </div>
          <div class="hero-stat-dark">
            <div class="stat-number-dark">78%</div>
            <p class="stat-text-dark">de las búsquedas móviles locales resultan en compra offline</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECCION QUE ES GOOGLE NEGOCIOS -->
  <section class="advantages-pymempresas">
    <div class="advantages-container">
      <div class="advantages-header">
        <p class="advantages-label">FUNDAMENTOS</p>
        <h2 class="advantages-title">¿Qué es <span class="text-highlight">Google Negocios</span>?</h2>
        <p class="advantages-subtitle">Google para Negocios (ahora llamado <strong>Perfil de Empresa de Google</strong>) es la herramienta gratuita que permite a tu negocio aparecer en Google Maps y en las búsquedas locales cuando los clientes buscan tus productos o servicios.</p>
      </div>

      <div class="gmb-grid-4">
        <div class="gmb-card">
          <div class="gmb-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h3 class="gmb-card-title">Optimización Geográfica</h3>
          <p class="gmb-card-description">Posicionar tu negocio en búsquedas locales cuando los usuarios buscan servicios 'cerca de mí' o en tu ciudad.</p>
        </div>

        <div class="gmb-card">
          <div class="gmb-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </div>
          <h3 class="gmb-card-title">Búsquedas con Intención Local</h3>
          <p class="gmb-card-description">Aparecer cuando alguien busca 'dentista en Gijón' o 'fontanero urgente Oviedo' en Google.</p>
        </div>

        <div class="gmb-card">
          <div class="gmb-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"></path>
              <path d="M3 9V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"></path>
            </svg>
          </div>
          <h3 class="gmb-card-title">Google Maps y Pack Local</h3>
          <p class="gmb-card-description">Dominar el 'Local Pack' de Google: los 3 resultados con mapa que aparecen en las primeras posiciones.</p>
        </div>

        <div class="gmb-card">
          <div class="gmb-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h3 class="gmb-card-title">Ficha de Google Business</h3>
          <p class="gmb-card-description">Optimización completa de tu perfil de Google My Business para maximizar visibilidad y conversiones.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION LOCAL PACK -->
  <section class="about-pymempresas">
    <div class="about-container">
      <div class="about-content">
        <div class="about-text">
          <h2 class="about-title">El "Local Pack" de Google</h2>
          <p>Cuando alguien busca un servicio local como "restaurante italiano cerca de mí" o "dentista en Oviedo", Google muestra un bloque especial con un mapa y los 3 negocios más relevantes. <strong>Estar en este Local Pack puede multiplicar por 10 tus visitas.</strong></p>

          <div class="local-pack-benefits">
            <div class="benefit-item">
              <svg class="benefit-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              <span>Apareces antes que los resultados orgánicos tradicionales</span>
            </div>
            <div class="benefit-item">
              <svg class="benefit-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              <span>Muestras tu ubicación, horario, teléfono y reseñas</span>
            </div>
            <div class="benefit-item">
              <svg class="benefit-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              <span>Los usuarios pueden llamarte o pedir direcciones con un clic</span>
            </div>
            <div class="benefit-item">
              <svg class="benefit-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              <span>Generas confianza inmediata con las valoraciones</span>
            </div>
          </div>
        </div>

        <div class="local-pack-simulation">
          <div class="local-pack-header">
            <svg class="map-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <h3>Tu Negocio</h3>
            <div class="business-rating">
              <span class="stars">★★★★★</span>
              <span class="rating-count">(127)</span>
            </div>
          </div>

          <div class="business-info">
            <p class="business-address">Calle Principal, 123 · Abierto hasta las 20:00</p>
          </div>

          <div class="local-pack-map">
            <div class="map-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
          </div>

          <p class="simulation-label">Simulación del Local Pack de Google</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION OPORTUNIDAD -->
  <section class="advantages-pymempresas">
    <div class="advantages-container">
      <div class="advantages-header">
        <p class="advantages-label">LA OPORTUNIDAD</p>
        <h2 class="advantages-title">¿Por qué tu negocio <span class="text-highlight">necesita salir en Google Maps</span>?</h2>
        <p class="advantages-subtitle">Si tu negocio atiende a clientes en una zona geográfica específica, actualizar tu ficha de Google Maps no es opcional: es la diferencia entre ser encontrado o ser invisible.</p>
      </div>

      <div class="opportunity-grid">
        <div class="searches-column">
          <h3 class="column-title">Tus clientes están buscando ahora mismo</h3>

          <div class="search-list">
            <div class="search-item">
              <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              <div class="search-content">
                <span class="search-query">"fontanero urgente Gijón"</span>
                <span class="search-volume">320 búsquedas/mes</span>
              </div>
            </div>

            <div class="search-item">
              <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              <div class="search-content">
                <span class="search-query">"dentista Oviedo opiniones"</span>
                <span class="search-volume">480 búsquedas/mes</span>
              </div>
            </div>

            <div class="search-item">
              <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              <div class="search-content">
                <span class="search-query">"restaurante cerca de mí"</span>
                <span class="search-volume">12.000 búsquedas/mes</span>
              </div>
            </div>

            <div class="search-item">
              <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              <div class="search-content">
                <span class="search-query">"abogado laboralista Asturias"</span>
                <span class="search-volume">210 búsquedas/mes</span>
              </div>
            </div>
          </div>

          <p class="searches-note"><strong>¿Quién se lleva estos clientes?</strong> Los negocios que aparecen en las primeras posiciones. Si no eres tú, es tu competencia.</p>
        </div>

        <div class="business-types-column">
          <h3 class="column-title">Tipos de negocios que más se benefician</h3>

          <div class="business-types-grid">
            <div class="business-type-item">
              <svg class="business-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <span>Clínicas y Consultas Médicas</span>
            </div>

            <div class="business-type-item">
              <svg class="business-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
              <span>Comercios y Tiendas Locales</span>
            </div>

            <div class="business-type-item">
              <svg class="business-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <span>Asesorías y Consultorías</span>
            </div>

            <div class="business-type-item">
              <svg class="business-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                <line x1="9" y1="9" x2="9.01" y2="9"></line>
                <line x1="15" y1="9" x2="15.01" y2="9"></line>
              </svg>
              <span>Restaurantes y Hostelería</span>
            </div>

            <div class="business-type-item">
              <svg class="business-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
              </svg>
              <span>Servicios de Reparación</span>
            </div>

            <div class="business-type-item">
              <svg class="business-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>Agencias y Servicios B2B</span>
            </div>
          </div>

          <p class="business-types-note">Y cualquier negocio que atienda clientes en una ubicación física o área de servicio</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION ROI BANNER -->
  <section class="roi-banner">
    <div class="roi-banner-container">
      <div class="roi-banner-content">
        <div class="roi-banner-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="20" x2="12" y2="10"></line>
            <line x1="18" y1="20" x2="18" y2="4"></line>
            <line x1="6" y1="20" x2="6" y2="16"></line>
          </svg>
        </div>

        <h2 class="roi-banner-title">El ROI del SEO Local supera al de cualquier otra inversión en marketing</h2>

        <p class="roi-banner-description">Mientras que los anuncios de pago tienen un coste continuo, el SEO Local genera un flujo constante de clientes cualificados con un coste decreciente por lead a lo largo del tiempo.</p>

        <div class="roi-banner-stats">
          <div class="roi-banner-stat">
            <div class="roi-stat-value">5-10x</div>
            <div class="roi-stat-label">ROI típico en 12 meses</div>
          </div>
          <div class="roi-banner-stat">
            <div class="roi-stat-value">-60%</div>
            <div class="roi-stat-label">Coste por lead vs PPC</div>
          </div>
          <div class="roi-banner-stat">
            <div class="roi-stat-value">+300%</div>
            <div class="roi-stat-label">Aumento tráfico local</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION CIUDADES -->
  <section class="advantages-pymempresas">
    <div class="advantages-container">
      <div class="advantages-header">
        <p class="advantages-label">COBERTURA REGIONAL</p>
        <h2 class="advantages-title">Google para Negocios en las principales <span class="text-highlight">ciudades de Asturias</span></h2>
        <p class="advantages-subtitle">Ofrecemos servicios especializados de SEO Local adaptados a las particularidades de cada ciudad asturiana. Conocemos el mercado local y la competencia.</p>
      </div>

      <div class="cities-grid">
        <div class="city-card">
          <div class="city-header">
            <div class="city-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="city-info">
              <h3 class="city-name">SEO Local Gijón</h3>
              <p class="city-population">+270.000 habitantes</p>
            </div>
          </div>
          <p class="city-description">La ciudad más poblada de Asturias con un tejido empresarial diverso y alta competencia digital.</p>
          <a href="/seo-local-gijon/" class="city-btn">Ver servicio en Gijón →</a>
        </div>

        <div class="city-card">
          <div class="city-header">
            <div class="city-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="city-info">
              <h3 class="city-name">SEO Local Oviedo</h3>
              <p class="city-population">+220.000 habitantes</p>
            </div>
          </div>
          <p class="city-description">Capital del Principado con concentración de servicios profesionales y administración.</p>
