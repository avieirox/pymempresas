              serviceType: 'Diseño Web',
              areaServed: { '@type': 'City', 'name': 'Gijón' },
            },
          },
        ],
      },
      founder: {
        '@type': 'Person',
        name: 'Arturo Vieiros',
        url: 'https://www.linkedin.com/in/arturovieiros/',
        sameAs: 'https://www.linkedin.com/in/arturovieiros/',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      url: Astro.site.href,
      name: 'PYMEMPRESAS',
      description: 'Agencia de Marketing Digital en Gijón — SEO Local, Diseño Web, IA para PYMES en Asturias.',
      publisher: {
        '@id': `${Astro.site}#business`,
      },
      inLanguage: 'es-ES',
    },
  ],
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="Ov_nXnMus9U0JDxfJWYrkQDrLElrxvKOAibcavzwZzo" />
    <!-- Google Analytics — deferred after load to remove from critical path -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XJL99638S8';
        s.async = true;
        document.head.appendChild(s);
        gtag('config', 'G-XJL99638S8');
      });
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={Astro.props.metaTitle}
      description={Astro.props.metaDescription}
      canonicalURL={canonicalURL}
      ogImage={Astro.props.ogImage}
      ogType={Astro.props.ogType}
      noindex={Astro.props.noindex}
      schema={Astro.props.schema}
    />
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
